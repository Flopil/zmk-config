/ {
    chosen {
        zmk,rgb-underglow = &myleds;
        zmk,rgb-keyboard = &myleds;
    };

    myleds: leds {
        compatible = "worldsemi,ws2812-spi";

        spi-dev = <&spi3>;

        chain-length = <78>;

        color-mapping = <LED_COLOR_ID_GREEN
                         LED_COLOR_ID_RED
                         LED_COLOR_ID_BLUE>;
    };
};

&spi3 {
    status = "okay";
};