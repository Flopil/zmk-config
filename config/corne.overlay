/ {
    chosen {
        zmk,rgb-underglow = &led_strip;
    };

    led_strip: led_strip {
        compatible = "worldsemi,ws2812-gpio";

        gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;

        chain-length = <27>;

        color-mapping = <LED_COLOR_ID_GREEN
                         LED_COLOR_ID_RED
                         LED_COLOR_ID_BLUE>;
    };
};