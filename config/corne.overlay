/ {
    chosen {
        zmk,rgb-underglow = &led_strip;
        zmk,rgb-keyboard = &led_strip;
    };

    led_strip: led_strip {
        compatible = "worldsemi,ws2812-spi";

        reg = <0>;
        spi-max-frequency = <4000000>;

        chain-length = <78>;

        spi-gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;

        color-mapping = <0 1 2>;
    };
};