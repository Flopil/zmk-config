&spi3 {
    status = "okay";

    perkey_rgb: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <65>;
    };

    underglow: ws2812@1 {
        compatible = "worldsemi,ws2812-spi";
        reg = <1>;
        spi-max-frequency = <4000000>;
        chain-length = <13>;
    };
};