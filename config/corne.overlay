/ {
    chosen {
        zmk,rgb-underglow = &led_strip;
    };

    led_strip: ws2812 {
        compatible = "worldsemi,ws2812-spi";

        label = "WS2812";

        /* SPI correct sur nice_nano (souvent spi1 ou spi3 selon board) */
        spi-max-frequency = <4000000>;

        chain-length = <78>;

        /* GPIO SPI controller */
        gpios = <&gpio0 15 GPIO_ACTIVE_HIGH>;
    };
};